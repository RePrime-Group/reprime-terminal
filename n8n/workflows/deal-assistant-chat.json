        "jsCode": "// Extract and validate the inbound request body.\n// Vercel API route is responsible for JWT validation; this workflow trusts user_id from body.\nconst body = $input.first().json.body || {};\nconst user_id = body.user_id;\nconst deal_id = body.deal_id;\nconst message = body.message;\nconst conversation_id = body.conversation_id || null;\n\nconst valid = Boolean(user_id && deal_id && message && typeof message === 'string' && message.trim().length > 0);\n\nreturn [{\n  json: {\n    valid,\n    user_id,\n    deal_id,\n    conversation_id,\n    message: message ? message.trim() : '',\n    error: valid ? null : 'Missing required fields: user_id, deal_id, message',\n    start_ts: Date.now()\n  }\n}];"
      },
