    {
      "parameters": {
        "jsCode": "const startTs = Number($('Extract Request').first().json.start_ts ?? Date.now());\nconst latency_ms = Date.now() - startTs;\n\nconst item = $input.first().json;\nconst output = (item.output ?? '').toString();\nconst intermediateSteps = Array.isArray(item.intermediateSteps) ? item.intermediateSteps : [];\n\n// Char/4 token estimate (industry approximation; exact counts deferred to direct Anthropic HTTP path)\nconst SYS_PROMPT_CHAR_BUDGET = 4500;\nconst HISTORY_AVG_CHARS = 2500;\nconst userMsg = ($('Select Conversation').first().json.message ?? '').toString();\n\nconst input_tokens = Math.ceil((SYS_PROMPT_CHAR_BUDGET + userMsg.length + HISTORY_AVG_CHARS) / 4);\nconst output_tokens = Math.ceil(output.length / 4);\n\nconst tool_calls = intermediateSteps.length > 0\n  ? intermediateSteps.map((s) => ({\n      tool: s?.action?.tool ?? null,\n      input: s?.action?.toolInput ?? null,\n      observation_preview: typeof s?.observation === 'string' ? s.observation.slice(0, 500) : null,\n    }))\n  : null;\n\nconst tool_calls_json = tool_calls ? JSON.stringify(tool_calls) : null;\n\nreturn [{\n  json: {\n    output,\n    latency_ms,\n    input_tokens,\n    output_tokens,\n    tool_calls,\n    tool_calls_json,\n  }\n}];\n"
      },
