NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Assistant
# Set to 1 to enable the assistant (defaults: on in dev, off in prod)
NEXT_PUBLIC_AI_ASSISTANT_ENABLED=1
# Set to 1 to return mocked responses instead of calling n8n (defaults: on in dev)
AI_USE_MOCK=1

# n8n (required from Phase 4 onward; Phase 2 healthcheck uses BASE_URL + HEALTHCHECK_PATH)
N8N_BASE_URL=https://primary-production-9ee0c.up.railway.app
N8N_WEBHOOK_PATH_CHAT=/webhook/deal-assistant
N8N_WEBHOOK_PATH_HISTORY=/webhook/deal-assistant/conversations
N8N_WEBHOOK_PATH_FEEDBACK=/webhook/deal-assistant/feedback
N8N_WEBHOOK_PATH_HEALTHCHECK=/webhook/ai-healthcheck
# Random secret shared between Vercel and n8n for internal callbacks
N8N_INTERNAL_TOKEN=

# Anthropic (server-side only — used by /api/ai/chat title generation
# and by the n8n ingestion workflow for Haiku contextualization)
ANTHROPIC_API_KEY=

# Phase 5 RAG providers (server-side only)
# Google Gemini — embeddings (gemini-embedding-001 @ 1536d)
GOOGLE_API_KEY=
# Cohere — rerank-3
COHERE_API_KEY=
